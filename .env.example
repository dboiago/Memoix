# ==========================================
# Memoix Environment Variables Template
# ==========================================
# Instructions:
# 1. Copy this file and rename it to `.env`
# 2. Replace the placeholder values with your actual API credentials
# 3. DO NOT commit your `.env` file to version control
# ==========================================

# ------------------------------------------
# Supabase (Cloud Sync)
# ------------------------------------------
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ------------------------------------------
# Google Drive (Personal Storage Backups)
# ------------------------------------------
# Desktop/Web requires both ID and Secret.
# Mobile OAuth may only require the Client ID depending on your setup.
GOOGLE_CLIENT_ID_DESKTOP=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET_DESKTOP=your_google_client_secret_here

# ------------------------------------------
# Microsoft OneDrive (Personal Storage Backups)
# ------------------------------------------
ONEDRIVE_CLIENT_ID=your_onedrive_client_id_here